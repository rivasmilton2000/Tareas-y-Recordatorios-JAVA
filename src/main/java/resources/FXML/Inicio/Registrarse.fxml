      <SVGPath fx:id="iconoTaskMind" content="M16 7h.01 M3.4 18H12a8 8 0 0 0 8-8V7a4 4 0 0 0-7.28-2.3L2 20 M20 7l2 .5-2 .5 M10 18v3 M14 17.75V21 M7 18a6 6 0 0 0 3.84-10.61" fill="transparent" layoutX="838.0" layoutY="170.0" scaleX="1.5" scaleY="1.5" stroke="#0b2745" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="2.0" styleClass="topbar-icon" />
      <Text layoutX="888.0" layoutY="195.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="brand-title" text="TaskMind">
         <font>
            <Font name="Segoe UI Bold" size="34.0" />
         </font>
      </Text>

      <!-- Cuadro de registro centrado -->
      <AnchorPane layoutX="710.0" layoutY="245.0" prefHeight="647.0" prefWidth="500.0" styleClass="option-card">
         <children>
            <Text layoutX="168.0" layoutY="49.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="brand-title" text="Crea tu cuenta">
               <font>
                  <Font name="Segoe UI Bold" size="24.0" />
               </font>
            </Text>

            <Text layoutX="108.0" layoutY="101.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="field-label" text="Nombre">
               <font>
                  <Font name="Segoe UI Bold" size="18.0" />
               </font>
            </Text>
            <TextField fx:id="txtNombre" layoutX="108.0" layoutY="129.0" prefHeight="30.0" prefWidth="285.0" promptText="nombre..." style="-fx-padding: 0 0 0 38;" styleClass="input-field" />
            <SVGPath fx:id="iconoNombre" content="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2 M12 3a4 4 0 1 1 0 8a4 4 0 1 1 0-8" fill="transparent" layoutX="113.0" layoutY="132.0" mouseTransparent="true" scaleX="0.65" scaleY="0.65" stroke="#0b2745" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="2.0" styleClass="topbar-icon" />

            <Text layoutX="108.0" layoutY="201.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="field-label" text="Correo electrónico">
               <font>
                  <Font name="Segoe UI Bold" size="18.0" />
               </font>
            </Text>
            <TextField fx:id="txtCorreo" layoutX="108.0" layoutY="233.0" prefHeight="30.0" prefWidth="285.0" promptText="correo electronico" style="-fx-padding: 0 0 0 38;" styleClass="input-field" />
            <SVGPath fx:id="iconoCorreo" content="M22 7l-8.991 5.727a2 2 0 0 1-2.009 0L2 7 M4 4H20A2 2 0 0 1 22 6V18A2 2 0 0 1 20 20H4A2 2 0 0 1 2 18V6A2 2 0 0 1 4 4Z" fill="transparent" layoutX="113.0" layoutY="236.0" mouseTransparent="true" scaleX="0.65" scaleY="0.65" stroke="#0b2745" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="2.0" styleClass="topbar-icon" />

            <Text layoutX="108.0" layoutY="301.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="field-label" text="Contraseña">
               <font>
                  <Font name="Segoe UI Bold" size="18.0" />
               </font>
            </Text>
            <PasswordField fx:id="txtPassword" layoutX="108.0" layoutY="317.0" prefHeight="30.0" prefWidth="285.0" promptText="contraseña..." style="-fx-padding: 0 0 0 38;" styleClass="input-field">
               <font>
                  <Font name="Segoe UI" size="13.0" />
               </font>
            </PasswordField>
            <SVGPath fx:id="iconoPassword" content="M2.586 17.414A2 2 0 0 0 2 18.828V21a1 1 0 0 0 1 1h3a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h1a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h.172a2 2 0 0 0 1.414-.586l.814-.814a6.5 6.5 0 1 0-4-4z M16.5 7.5h.01" fill="transparent" layoutX="113.0" layoutY="320.0" mouseTransparent="true" scaleX="0.65" scaleY="0.65" stroke="#0b2745" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="2.0" styleClass="topbar-icon" />

            <Text layoutX="108.0" layoutY="401.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="field-label" text="Tipo de usuario">
               <font>
                  <Font name="Segoe UI Bold" size="18.0" />
               </font>
            </Text>
            <ComboBox fx:id="cmbTipoUsuario" layoutX="108.0" layoutY="425.0" prefHeight="30.0" prefWidth="285.0" promptText="USUARIO" styleClass="input-combo">
