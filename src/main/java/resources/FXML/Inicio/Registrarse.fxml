                  <FXCollections fx:factory="observableArrayList">
                     <String fx:value="CLASICO" />
                     <String fx:value="PREMIUM" />
                  </FXCollections>
               </items>
            </ComboBox>

            <Button layoutX="108.0" layoutY="532.0" onAction="#registrar" mnemonicParsing="false" prefHeight="35.0" prefWidth="285.0" styleClass="topbar-button" text="Crear cuenta" textAlignment="CENTER">
               <font>
                  <Font name="Segoe UI Bold" size="18.0" />
               </font>
            </Button>

            <Text layoutX="108.0" layoutY="632.0" onMouseClicked="#irLogin" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="link-text" text="¿Ya tienes una cuenta? Iniciar sesión">
               <font>
