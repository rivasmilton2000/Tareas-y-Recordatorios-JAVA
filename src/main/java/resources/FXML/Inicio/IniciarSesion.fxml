<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane maxHeight="1080.0" maxWidth="1920.0" minHeight="1080.0" minWidth="1920.0" prefHeight="1080.0" prefWidth="1920.0" styleClass="main-background" stylesheets="@style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controlador.LoginController">
   <children>

      <!-- Logo superior fuera del cuadro de inicio de sesión -->
      <SVGPath fx:id="iconoTaskMind" content="M16 7h.01 M3.4 18H12a8 8 0 0 0 8-8V7a4 4 0 0 0-7.28-2.3L2 20 M20 7l2 .5-2 .5 M10 18v3 M14 17.75V21 M7 18a6 6 0 0 0 3.84-10.61" fill="transparent" layoutX="838.0" layoutY="190.0" scaleX="1.5" scaleY="1.5" stroke="#4A90E2" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="2.0" styleClass="topbar-icon" />
      <Text layoutX="888.0" layoutY="215.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="brand-title" text="TaskMind">
         <font>
            <Font name="Segoe UI Bold" size="34.0" />
         </font>
      </Text>

      <!-- Cuadro de inicio de sesión centrado -->
      <AnchorPane layoutX="710.0" layoutY="300.0" prefHeight="510.0" prefWidth="500.0" styleClass="option-card">
         <children>
            <Text layoutX="173.0" layoutY="54.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="brand-title" text="Iniciar sesión">
               <font>
                  <Font name="Segoe UI Bold" size="24.0" />
               </font>
            </Text>

            <Text layoutX="108.0" layoutY="126.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="field-label" text="Correo electrónico">
               <font>
                  <Font name="Segoe UI Bold" size="18.0" />
               </font>
            </Text>
            <TextField fx:id="txtCorreo" layoutX="108.0" layoutY="154.0" prefHeight="30.0" prefWidth="285.0" promptText="correo electrónico..." style="-fx-padding: 0 0 0 38;" styleClass="input-field" />
            <SVGPath fx:id="iconoCorreo" content="M22 7l-8.991 5.727a2 2 0 0 1-2.009 0L2 7 M4 4H20A2 2 0 0 1 22 6V18A2 2 0 0 1 20 20H4A2 2 0 0 1 2 18V6A2 2 0 0 1 4 4Z" fill="transparent" layoutX="115.0" layoutY="157.0" mouseTransparent="true" scaleX="0.65" scaleY="0.65" stroke="#4A90E2" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="2.0" styleClass="topbar-icon" />

            <Text layoutX="108.0" layoutY="246.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="field-label" text="Contraseña">
               <font>
                  <Font name="Segoe UI Bold" size="18.0" />
               </font>
            </Text>
            <PasswordField fx:id="txtPassword" layoutX="108.0" layoutY="274.0" prefHeight="30.0" prefWidth="285.0" promptText="contraseña..." style="-fx-padding: 0 0 0 38;" styleClass="input-field">
               <font>
                  <Font name="Segoe UI" size="13.0" />
               </font>
            </PasswordField>
            <SVGPath fx:id="iconoPassword" content="M2.586 17.414A2 2 0 0 0 2 18.828V21a1 1 0 0 0 1 1h3a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h1a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h.172a2 2 0 0 0 1.414-.586l.814-.814a6.5 6.5 0 1 0-4-4z M16.5 7.5h.01" fill="transparent" layoutX="115.0" layoutY="277.0" mouseTransparent="true" scaleX="0.65" scaleY="0.65" stroke="#4A90E2" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="2.0" styleClass="topbar-icon" />

            <Button fx:id="btnIniciarSesion" onAction="#iniciarSesion" layoutX="108.0" layoutY="365.0" mnemonicParsing="false" prefHeight="35.0" prefWidth="285.0" styleClass="topbar-button" text="Iniciar sesión" textAlignment="CENTER">
               <font>
                  <Font name="Segoe UI Bold" size="18.0" />
               </font>
            </Button>

            <Text layoutX="130.0" layoutY="465.0" onMouseClicked="#irRegistro" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="link-text" text="¿No tienes cuenta? Crear cuenta">
               <font>
                  <Font name="Segoe UI Bold" size="16.0" />
               </font>
            </Text>
         </children>
         <opaqueInsets>
            <Insets />
         </opaqueInsets>
      </AnchorPane>
   </children>
</AnchorPane>

